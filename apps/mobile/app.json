{
  "expo": {
    "name": "Gymnasia",
    "slug": "gymnasia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.maximofn.gymnasia",
      "supportsTablet": true
    },
    "android": {
      "package": "com.maximofn.gymnasia"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "939caf71-3ed8-49a4-a3e9-d60c2a8da194"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
