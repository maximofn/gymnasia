{
  "name": "gymnasia",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "expo": {
      "react-native": "0.74.5"
    },
    "react-native": "0.74.5"
  },
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload",
    "build:web": "npm --workspace apps/web run build"
  }
}
